# ----------------------------------------------------------------------------
# AICOS environment variables (TEMPLATE)
# Copy this file to ".env" and fill in real values. NEVER commit ".env".
# Do NOT paste secrets in chat, issues, or commits.
# ----------------------------------------------------------------------------

# --- AI providers ---
# Anthropic Claude (mid-tier: Haiku, premium: Sonnet/Opus)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxx

# Local Ollama (Tier-1 cheap tasks). Default local endpoint.
OLLAMA_BASE_URL=http://localhost:11434

# Image generation provider (set when wiring the Image agent)
IMAGE_API_KEY=

# --- Supabase (Postgres + pgvector + Auth + Realtime) ---
# Python agents use SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY (writes).
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BRAND_ID=
DATABASE_URL=
# Next.js dashboard reads these (must be prefixed NEXT_PUBLIC_; put in
# apps/dashboard/.env.local for local dev, or Vercel env vars in prod):
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Gate the dashboard behind the single-admin magic-link login. Leave unset for
# a local single-user setup; set to "true" for public deployments.
NEXT_PUBLIC_REQUIRE_AUTH=

# --- Upstash Redis (queue + cache) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Cloudflare R2 (media storage) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# --- Social platforms (publishing) ---
# Meta Graph API (Instagram Business/Creator linked to a Facebook Page)
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
IG_BUSINESS_ACCOUNT_ID=

# YouTube Data API (OAuth)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# --- App config ---
NODE_ENV=development
APP_BASE_URL=http://localhost:3000
