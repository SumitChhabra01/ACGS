{
  "name": "aicos",
  "version": "0.1.0",
  "private": true,
  "description": "AICOS — AI Autonomous Content Operating System (lean serverless MVP)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace apps/dashboard",
    "build": "npm run build --workspace apps/dashboard",
    "lint": "npm run lint --workspace apps/dashboard",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=20"
  }
}
